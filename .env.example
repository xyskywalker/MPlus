# ===========================
# MPlus 环境变量配置模板
# ===========================

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库
DATABASE_URL=sqlite:///./data/mplus.db

# 简单登录（单用户）
AUTH_USERNAME=admin
AUTH_PASSWORD=Admin123

# ===========================
# 注意：模型配置已移至 Web UI
# ===========================
# 模型配置（API Key、终结点、模型名称等）通过 Web 界面配置
# 支持多个模型配置，灵活切换
# 启动后访问：设置 -> 模型配置

# ===========================
# Ripple 模拟引擎配置
# ===========================

# 模拟引擎：ripple（真实引擎）/ mock（开发测试）
SIMULATION_ENGINE=ripple

# 自定义 Skill 目录（留空使用 Ripple 内置）
RIPPLE_SKILL_PATH=

# 最大传播轮数（48h / 2h per wave）
RIPPLE_MAX_WAVES=24

# 单次模拟 LLM 调用上限
RIPPLE_MAX_LLM_CALLS=300

# 集成运行次数（1=单次，3=集成模式）
RIPPLE_ENSEMBLE_RUNS=1

# 合议庭辩论轮数（上限 4）
RIPPLE_DELIBERATION_ROUNDS=3

# 模拟时间跨度（小时）
RIPPLE_SIMULATION_HOURS=48
